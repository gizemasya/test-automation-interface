              "issue_id": "608002",
              "issue_key": "KT-395",
              "issuetype": "Test",
              "summary": "2.4 GHz Bandı Sweep Kazanç Testi",
              "description": "h2. 1.1 Amaç\n\nBu testin amacı; DUT'un 2400 MHz ile 2500 MHz arasında sinyal jeneratörü ile süpürülmesi (sweep) ve spektrum analizör ile elde edilen çıkış gücünün ölçülerek, band içerisindeki kazanç düzlüğünün (gain flatness) doğrulanmasıdır.",
              "status": "Open",
              "priority": "High",
              "reporter": "Test Muhendisi",
              "assignee": "Test Muhendisi",
              "environment": {
                "spec_limit": {
                  "id": 2,
                  "test_step_def_id": 102,
                  "limit_name": "Gain_Flatness_Check",
                  "limit_type": "PassFail",
                  "nominal_value": 15.0,
                  "min_value": 13.0,
                  "max_value": 17.0,
                  "tolerance_value": 2.0,
                  "tolerance_unit": "dB",
                  "unit": "dBm"
                }
              },
              "labels": [],
              "components": [],
              "fix_versions": [],
              "custom_fields": {},
              "steps": [
                {
                  "index": 1,
                  "action": "Güç Kaynağı panelinden bağlantıyı gerçekleştirin.\nVoltaj: 12.0 V, Akım: 2.0 A girin ve 'SET DEĞERLERİ GÖNDER' butonuna basın.\n'OUTPUT ON' butonuna basarak cihaza güç verin.",
                  "data": "12.0 V, 2.0 A",
                  "expected_result": "Güç kaynağının açıldığı ve panelde anlık voltaj/akım değerlerinin (yaklaşık 12V ve cihazın çektiği akım) görüldüğü teyit edilmelidir.",
                  "attachments": []
                },
                {
                  "index": 2,
                  "action": "Spektrum Analizör panelinden bağlantıyı gerçekleştirin.\nCenter Freq: 2450 MHz, Span: 150 MHz, RBW: 100 kHz ayarlayın.\n'SÜREKLİ ÖLÇÜM' butonuna basarak ölçümü başlatın.",
                  "data": "Center: 2450, Span: 150, RBW: 100",
                  "expected_result": "Grafik ekranında spektrum gürültü tabanının ve merkez frekansın güncellendiği görülmelidir.",
                  "attachments": []
                },
                {
                  "index": 3,
                  "action": "Sinyal Jeneratörü panelinden 'Sweep' modunu seçin.\nBaşlangıç: 2400 MHz, Bitiş: 2500 MHz, Adım: 10 MHz, Bekleme: 0.5 s, Güç: -10 dBm olarak ayarlayın.\n'BAŞLAT' butonuna basın.",
                  "data": "Start: 2400, Stop: 2500, Step: 10, Power: -10 dBm",
                  "expected_result": "Jeneratörün adım adım frekans taraması yaptığı log ekranında görülmeli ve grafik ekranında hareket eden mavi dikey çizgi (GEN marker) ile kırmızı sinyal tepeleri (Peak) izlenmelidir.",
                  "attachments": []
                },
                {
                  "index": 4,
                  "action": "Sweep işlemi tamamlanana (DURDUR butonu tekrar BAŞLAT olana) kadar bekleyin.\nİşlem bitince Grafik sekmesinden 'VERİYİ CSV KAYDET' butonuna tıklayın.",
                  "data": "",
                  "expected_result": "Otomatik oluşturulan grafik verisi CSV dosyasının başarıyla kaydedildiğine dair uyarı alınmalıdır.",
                  "attachments": []
                },
                {
                  "index": 5,
                  "action": "Tüm ölçüm tamamlandığında Genel Kontrol bölümünden 'LOG CSV KAYDET' diyerek test loglarını kayıt altına alın.\nArdından Güç Kaynağı panelinden 'OUTPUT OFF' a tıklayarak testi sonlandırın.",
                  "data": "",
                  "expected_result": "Log verileri gün ve saat damgalı olarak diske kaydedilmeli ve DUT'un gücü kesilmelidir.",
                  "attachments": []
                }
              ],
